{
  "compilerOptions": {
    "target": "es2018",
    "lib": ["dom", "es2018"],
    "jsx": "react",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/main.jsx"],
  "exclude": ["node_modules", "build"]
}
